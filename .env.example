# ---- Cribl Search OTLP ingress (used by the OTel collector in the kind cluster) ----

# Cribl Search OTLP endpoint (e.g., default.main.my-org-id.cribl.cloud:20000)
CRIBL_ENDPOINT=

# Credentials for OTLP basic auth
CRIBL_USERNAME=
CRIBL_PASSWORD=

# ---- Cribl MCP Server (used by Claude Code via scripts/cribl-mcp.sh) ----
#
# These are DIFFERENT from the OTLP credentials above — they are Cribl Cloud
# API credentials (OAuth client ID + secret), created under
# Organization → API Credentials in the Cribl Cloud UI.
# See: https://docs.cribl.io/cribl-as-code/api-auth

# Base URL of your Cribl Cloud workspace
# e.g. https://default-my-org-id.cribl.cloud  (note: NOT the OTLP ingress host)
CRIBL_BASE_URL=

CRIBL_CLIENT_ID=
CRIBL_CLIENT_SECRET=

# Optional: require an API key on requests to the local MCP server. Leave
# blank for unauthenticated localhost-only access (fine for dev).
# CRIBL_MCP_API_KEY=
