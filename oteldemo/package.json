{
  "name": "oteldemo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "package": "npm run build && node scripts/package.mjs",
    "deploy": "node scripts/deploy.mjs"
  },
  "dependencies": {
    "d3-array": "^3.2.4",
    "d3-force": "^3.0.0",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-time": "^3.1.0",
    "d3-time-format": "^4.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/d3-array": "^3.2.2",
    "@types/d3-force": "^3.0.10",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.8",
    "@types/d3-time": "^3.0.4",
    "@types/d3-time-format": "^4.0.3",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  },
  "displayName": "OpenTelemetry Demo",
  "description": "Visualize data from the OpenTelemetry demo",
  "author": "Clint Sharp",
  "navItems": [
    {
      "path": "/",
      "label": "Home"
    },
    {
      "path": "/search",
      "label": "Search"
    },
    {
      "path": "/architecture",
      "label": "System Architecture"
    },
    {
      "path": "/compare",
      "label": "Compare"
    },
    {
      "path": "/service/:serviceName",
      "label": "Service Detail",
      "hidden": true
    },
    {
      "path": "/trace/:traceId",
      "label": "Trace Detail",
      "hidden": true
    }
  ]
}
